{
  "name": "@paradigmllc/blocks",
  "version": "0.5.0",
  "description": "Paradigm Sales OS v2 — Block discriminated union renderer (cms_content_blocks 用) shared between Appexxme + paradigmjpcom. v0.5.0 adds 5 research-grade blocks (cover_summary / methodology / industry_context / risk_quantification / appendix_references) — Gartner/Forrester/McKinsey IR 級の構成設計.",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./BlockRenderer": {
      "types": "./src/BlockRenderer.tsx",
      "default": "./src/BlockRenderer.tsx"
    },
    "./BlocksReportRenderer": {
      "types": "./src/BlocksReportRenderer.tsx",
      "default": "./src/BlocksReportRenderer.tsx"
    },
    "./blocks/*": {
      "types": "./src/blocks/*.tsx",
      "default": "./src/blocks/*.tsx"
    },
    "./magicui/*": {
      "types": "./src/_magicui/*.tsx",
      "default": "./src/_magicui/*.tsx"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "framer-motion": "^12.0.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Paradigmllc/paradigm-blocks"
  },
  "author": "Paradigm LLC",
  "keywords": [
    "paradigm",
    "blocks",
    "cms-content-blocks",
    "diagnostic-report"
  ]
}
