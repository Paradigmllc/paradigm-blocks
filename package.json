{
  "name": "@paradigmllc/blocks",
  "version": "1.0.0",
  "description": "Paradigm Sales OS v2 — Block discriminated union renderer (cms_content_blocks 用). v1.0.0 (D-12 / 2026-05-08) introduces 主治医カルテ型 7 Karte Blocks (KarteCover/ChiefComplaint/Examination/Diagnosis/Prescription/FollowUp/Consultation) with strict A-CONTENT compliance — all visible content via props, all colors/fonts via CSS variables only. ThemeProvider gains DB-injected `tokens` prop for CMS-editable design tokens. Legacy 36 blocks retained for backward-compat.",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./BlockRenderer": {
      "types": "./src/BlockRenderer.tsx",
      "default": "./src/BlockRenderer.tsx"
    },
    "./BlocksReportRenderer": {
      "types": "./src/BlocksReportRenderer.tsx",
      "default": "./src/BlocksReportRenderer.tsx"
    },
    "./blocks/*": {
      "types": "./src/blocks/*.tsx",
      "default": "./src/blocks/*.tsx"
    },
    "./magicui/*": {
      "types": "./src/_magicui/*.tsx",
      "default": "./src/_magicui/*.tsx"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "framer-motion": "^12.0.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Paradigmllc/paradigm-blocks"
  },
  "author": "Paradigm LLC",
  "keywords": [
    "paradigm",
    "blocks",
    "cms-content-blocks",
    "diagnostic-report"
  ]
}
